# ── Executor service environment ─────────────────────────────────────────────
# Copy to .env and fill in values before running locally.

# HTTP port (default: 4300)
PORT=4300

# Identifier for this node — must match the nodeId registered with the
# notification service via PUT /nodes/:nodeId.
NODE_ID=pi-01

# Absolute path to the local git checkout that the executor will work in.
# The executor will git-checkout the dispatched branch inside this directory.
REPO_PATH=/home/pi/open-tomato

# Base URL of the notifications service.
# When absent the executor uses the console-only stub client (local dev).
NOTIFICATION_URL=http://localhost:4400

# PostgreSQL connection string for job/task/worker state persistence.
# Start Postgres via `bun db:start` then run `bun db:migrate`.
DATABASE_URL=postgresql://executor:executor@localhost:5434/executor

# Default worker type for the auto-registered worker at startup.
# "local" = Bun.spawn (default), "docker" = requires Docker.
# Additional workers can be registered at runtime via PUT /workers/:workerId.
WORKER_MODE=local

# ── Simulation mode ───────────────────────────────────────────────────────────
# Enable with DRY_RUN=true or by passing --dry-run at startup.
# When active the service uses the simulator instead of real claude invocations.
# DRY_RUN=true

# Time to wait between simulated tasks (ms). Ignored when SIMULATOR_TOTAL_MS is set.
# SIMULATOR_TASK_INTERVAL_MS=3000

# Total simulated run-time (ms) split equally across all tasks in the plan.
# Overrides SIMULATOR_TASK_INTERVAL_MS when set.
# SIMULATOR_TOTAL_MS=

# Inject a failure after this many tasks complete successfully.
# 0 (default) means no failure is injected.
# SIMULATOR_FAIL_AFTER=0

# Type of failure to simulate: task-exit | workspace | prerequisites
# SIMULATOR_FAIL_REASON=task-exit
