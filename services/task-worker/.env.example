# Task-worker service configuration
# Copy to .env before running locally.

# HTTP listen port
PORT=4310

# Worker identifier (unique per instance)
WORKER_ID=task-worker-0

# Default model preset (must be in the approved registry)
# Options: opus, sonnet, haiku, local-qwen-14b
DEFAULT_MODEL=sonnet

# Hive learning orchestrator URL (optional)
# When set, instincts are bootstrapped on startup and flushed on shutdown.
# When absent, instinct lifecycle is skipped (local-only mode).
ORCHESTRATOR_URL=

# Anthropic API key (required for remote Anthropic models)
ANTHROPIC_API_KEY=
