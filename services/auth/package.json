{
  "name": "@open-tomato/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch index.ts",
    "start": "bun index.ts",
    "build": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "lint": "eslint --fix",
    "test": "vitest run",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/db/seed.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@open-tomato/errors": "workspace:^",
    "@open-tomato/express": "workspace:^",
    "@open-tomato/service-core": "workspace:^",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "otplib": "^12.0.1",
    "pg": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@open-tomato/eslint-config": "workspace:^",
    "@open-tomato/typescript-config": "workspace:^",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.6"
  }
}
