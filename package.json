{
  "name": "@open-tomato/packages-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "shared/*",
    "service/*",
    "notifications/*",
    "ui-skeleton"
  ],
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "release": "changeset publish",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@types/bun": "latest",
    "publint": "^0.3.9",
    "shadcn": "^4.7.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
