{
  "name": "@open-tomato/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "app",
    "services/*",
    "types",
    "cli",
    "templates/*",
    "packages/shared/*",
    "packages/service/*",
    "packages/notifications/*",
    "packages/agents/*",
    "packages/ui-skeleton"
  ],
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "dev:stack": "docker compose up --build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@open-tomato/eslint-config": "workspace:^",
    "@open-tomato/typescript-config": "workspace:^",
    "@types/bun": "latest",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
